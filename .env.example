# ── LLM API Keys ─────────────────────────────────────────────────────────────
# At least one is required. Anthropic Claude is the recommended default.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Optional: for AWS Bedrock, Google Gemini, Azure OpenAI
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/

# ── Database (for quick CLI usage: sqlagent serve --db <url>) ─────────────────
# Leave blank to use the workspace setup wizard instead.
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
# DATABASE_URL=sqlite:///path/to/my.db
# DATABASE_URL=snowflake://user:pass@account/database

# ── Observability (optional) ──────────────────────────────────────────────────
# OpenTelemetry — export traces to Jaeger, Honeycomb, Datadog, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=sqlagent

# Langfuse — LLM observability dashboard
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Server settings ───────────────────────────────────────────────────────────
# SQLAGENT_HOST=0.0.0.0
# SQLAGENT_PORT=8080
# SQLAGENT_LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
# Enable JWT auth for multi-user deployments (default: disabled for local dev)
# SQLAGENT_AUTH_ENABLED=true
# SQLAGENT_JWT_SECRET=change-me-to-a-long-random-string

# ── Model config ──────────────────────────────────────────────────────────────
# Default: claude-sonnet-4-5. Override here or in the Settings UI.
# SQLAGENT_LLM_MODEL=gpt-4o
# SQLAGENT_LLM_PROVIDER=openai
